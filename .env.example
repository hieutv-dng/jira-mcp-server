# Jira Configuration
# URL gốc của Jira nội bộ (không có dấu / ở cuối)
JIRA_BASE_URL=https://your_jira_server.your_domain.com

# Personal Access Token — lấy tại:
# Jira → Profile → Personal Access Tokens → Create Token
JIRA_PAT=your_personal_access_token_here

# (Optional) Project key mặc định nếu chỉ làm 1 project
JIRA_DEFAULT_PROJECT=YOUR_PROJECT_KEY

# HTTP Transport (multi-tenant mode)
# Bỏ trống / không set HTTP_PORT để chạy stdio (Claude Desktop, Cursor, Windsurf).
# Set HTTP_PORT để bật HTTP transport (Express + Bearer auth).
HTTP_PORT=
# Bắt buộc khi HTTP_PORT được set — Bearer token cho client gọi /mcp
MCP_AUTH_TOKEN=